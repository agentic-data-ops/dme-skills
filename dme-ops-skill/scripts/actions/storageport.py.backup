def eth_port_list(client: DMEAPIClient, storage_id: str = None, location: str = None,
                  ipv4: str = None, ipv6: str = None, port_name: str = None) -> dict:
    """
    查询存储设备 eth 端口信息

    使用 /rest/storagemgmt/v1/storages/eth-ports/query 接口

    Args:
        client: DME API 客户端
        storage_id: 存储设备的 ID（可选，1~36 个字符）
        location: 位置（可选，1~255 个字符）
        ipv4: ipv4 地址（可选，1~255 个字符）
        ipv6: ipv6 地址（可选，1~255 个字符）
        port_name: 端口名称（可选，1~255 个字符）

    Returns:
        响应数据，包含 total 和 eth_ports 字段
    """
    url = "/rest/storagemgmt/v1/storages/eth-ports/query"

    payload = {}

    if storage_id is not None:
        payload['storage_id'] = storage_id
    if location is not None:
        payload['location'] = location
    if ipv4 is not None:
        payload['ipv4'] = ipv4
    if ipv6 is not None:
        payload['ipv6'] = ipv6
    if port_name is not None:
        payload['port_name'] = port_name

    response = client.post(url, json=payload)
    return response


