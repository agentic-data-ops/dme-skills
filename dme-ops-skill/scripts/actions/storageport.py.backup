    response = client.get(url)
    return response


def fc_port_list(client: DMEAPIClient, storage_id: str = None, page_no: int = 1, page_size: int = 20) -> dict:
    """
    批量查询存储 FC 端口

    使用 /rest/storagemgmt/v1/frontend-ports/fc-ports/query 接口

    Args:
        client: DME API 客户端
        storage_id: 存储设备 id（可选，1~64 个字符）
        page_no: 分页查询的页码（可选，1~10000，默认 1）
        page_size: 分页查询的每页大小（可选，1~1000，默认 20）

    Returns:
        响应数据，包含 total 和 ports 字段
    """
    url = "/rest/storagemgmt/v1/frontend-ports/fc-ports/query"

    payload = {
        'page_no': page_no,
        'page_size': page_size
    }

    if storage_id is not None:
        payload['storage_id'] = storage_id

    response = client.post(url, json=payload)
    return response


